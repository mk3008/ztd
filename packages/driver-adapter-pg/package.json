{
  "name": "@ashiba/driver-adapter-pg",
  "version": "0.0.0",
  "description": "Thin Ashiba adapter for pg clients.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:live": "vitest run tests/postgres-live.smoke.test.ts",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@ashiba/driver-adapter-core": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "fast-check": "^4.8.0",
    "pg": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
